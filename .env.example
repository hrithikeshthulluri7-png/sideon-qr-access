# ===============================================
# SIDEON QR Access Control System - Environment
# ===============================================
# Copy to .env for local use. Keep real secrets out of version control.

# Runtime mode: development, production, or test.
NODE_ENV=development

# HTTP port used by the Node.js API server.
PORT=3001

# Bind address for the API server inside Docker or on the host.
HOST=0.0.0.0

# Secret used to sign JWTs. Replace with a generated 32-byte hex value.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-generated-32-byte-hex-secret

# JWT lifetime accepted by jsonwebtoken, for example 1h, 30m, or 1d.
JWT_EXPIRY=1h

# QR token lifetime in minutes before a token is considered expired.
EXPIRATION_MINUTES=60

# SQLite database file path for non-Docker runs.
DATABASE_URL=./data/sideon.db

# Directory where automatic SQLite backups are written.
DATABASE_BACKUP_DIR=./data/backups

# Number of days to keep database backup files.
DATABASE_BACKUP_RETENTION_DAYS=30

# Comma-separated browser origins allowed to call the API directly.
CORS_ORIGIN=http://localhost:8080,http://localhost:8000,http://localhost:3000

# Whether CORS responses should include Access-Control-Allow-Credentials.
CORS_CREDENTIALS=false

# Maximum accepted request Content-Length in bytes.
MAX_CONTENT_LENGTH=102400

# Application log level: error, warn, info, or debug.
LOG_LEVEL=info

# Directory where application and request logs are written.
LOG_DIR=./logs

# Maximum size of each log file before rotation, for example 10M or 500K.
LOG_FILE_MAX_SIZE=10M

# Maximum number of rotated log files to keep.
LOG_FILE_MAX_FILES=14

# Enable structured request logging unless set to false.
LOG_REQUESTS=true

# Include request bodies in request logs. Keep false for privacy.
LOG_REQUEST_BODY=false

# Number of days to keep audit log rows.
AUDIT_LOG_RETENTION_DAYS=90

# Number of days to keep expired token rows during cleanup.
EXPIRED_TOKEN_RETENTION_DAYS=30

# Git commit SHA exposed by /api/version.
GIT_COMMIT_SHA=local

# Deployment timestamp exposed by /api/version.
DEPLOYMENT_DATE=development

# Application version exposed by health and version endpoints.
VERSION=1.0.0

# Enable /api/health reporting in version metadata.
ENABLE_HEALTH_CHECK=true

# Enable /api/version reporting in version metadata.
ENABLE_VERSION_ENDPOINT=true

# Enable /api/metrics. Set false to disable metrics access.
ENABLE_METRICS=false

# Enable request validation reporting in version metadata.
ENABLE_REQUEST_VALIDATION=true

# Reserved feature flag for future CSRF protection.
ENABLE_CSRF_PROTECTION=false

# Load-test target base URL used by load-test-runner.js.
BASE_URL=http://localhost:3001

# Load-test scenario: happy-path, stress, or endurance.
SCENARIO=happy-path
